/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    /*
    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Methylation
    ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    */

    withName: '.*:CALL_METHYLATION_MODKIT:.*' {
        publishDir = [
            enabled: false,
        ]
    }

    withName: '.*:CALL_METHYLATION_MODKIT:MODKIT_PILEUP' {
        ext.args = { [
            "${params.extra_modkit_options}",
            '--cpg',
            '--combine-strands',
            !params.skip_phasing ? '--phased' : '',
            "--modified-bases ${params.modkit_modified_bases}",
        ].join(' ') }
        ext.prefix = { "${meta.id}_modkit_pileup" }
        publishDir = [
            path: { "${params.outdir}/methylation/pileup/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.log') ? filename : null }
        ]
    }


    withName: '.*:CALL_METHYLATION_MODKIT:TABIX_BGZIPTABIX' {
        ext.prefix = { "${input.simpleName}" }
        publishDir = [
            path: { "${params.outdir}/methylation/pileup/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*CALL_METHYLATION_MODKIT:MODKIT_BEDMETHYLTOBIGWIG' {
        ext.prefix = { "${bedmethyl.simpleName}" }
        publishDir = [
            path: { "${params.outdir}/visualization_tracks/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}
