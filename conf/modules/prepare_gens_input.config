process {

    withName: '.*:PREPARE_GENS_INPUTS:.*' {
        publishDir = [
            enabled: false,
        ]
    }

    withName: '.*PREPARE_GENS_INPUTS:MOSDEPTH' {
        ext.args = {
            [
                '-n',
                '--fast-mode',
                '--by 100',
            ].join(' ')
        }
    }

    withName: '.*PREPARE_GENS_INPUTS:BCFTOOLS_CONCAT' {
        ext.args = {
            [
                '--allow-overlaps',
                '--output-type z',
                '--write-index=tbi',
            ].join(' ')
        }
    }

    withName: '.*PREPARE_GENS_INPUTS:SAMTOOLS_VIEW' {
        ext.args = '-H --output-fmt sam'
        ext.prefix = { "${meta.id}.mosdepth_gatk_header" }
    }

    withName: '.*PREPARE_GENS_INPUTS:MOSDEPTH_GATK_HEADER' {
        ext.args = { "-v sample=${meta.id}"}
        ext.args2 = '\'{ print } END { print "@RG\\tID:GATKCopyNumber\\tSM:" sample; print "CONTIG\\tSTART\\tEND\\tCOUNT" }\''
        ext.prefix = { "${meta.id}" }
        ext.suffix = 'mosdepth_gatk_header.tsv'
    }

    withName: '.*PREPARE_GENS_INPUTS:CAT_CAT' {
        ext.prefix = { "${meta.id}.concat" }
    }

    withName: '.*PREPARE_GENS_INPUTS:MOSDEPTH_GATK_FORMAT' {
        ext.prefix = { "${meta.id}.gatk_formatted" }
        ext.args = { "-v sample=${meta.id}"}
        ext.args2 = '\'BEGIN { OFS="\\t" } FNR==NR { gsub("SAMPLE_NAME", sample); print; next } { $4 = int($4 + 0.5); $2++; print $1, $2, $3, $4 }\''
    }

    withName: '.*PREPARE_GENS_INPUTS:GENERATE_GENS_DATA' {
        publishDir = [
            path: { "${params.outdir}/gens/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }
}
