process {
    withName: 'BEDTOOLS_MERGE' {
        ext.prefix = { "${meta.id}_merged" }
    }
    withName: 'BEDTOOLS_SORT' {
        ext.prefix = { "${meta.id}_sorted" }
    }
    withName: 'BEDTOOLS_SPLIT' {
        ext.prefix = { "${meta.id}_chunk" }
        ext.args =  '-a size'
    }
    withName: 'GAWK_EXTRACT_REGIONS' {
    ext.prefix = { "${meta.id}_${meta.genome}" }
    ext.args2  = { meta.genome == "mt" ? '\'\$1 == "chrM" || \$1 == "MT" || \$1 == "chrMT"\'' : '\'\$1 != "chrM" && \$1 != "MT" && \$1 != "chrMT"\'' }
    }
}
