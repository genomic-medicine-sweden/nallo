// FIXME: Look through and test this
// FIXME: Run both with and without pon stubs

nextflow_workflow {

    name "Test Workflow PREPARE_GENS_INPUTS"
    script "../main.nf"
    workflow "PREPARE_GENS_INPUTS"

    options "-stub"

    // input[2] = "$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/baf_positions.tsv"

    test("prepare_gens_inputs") {
        when {
            workflow {
                """
                def meta = [ id: 'HG002', single_end: false ]
                input[0] = Channel.of([
                    meta,
                    file('$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/hg002_region.bam', checkIfExists: true),
                    file('$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/hg002_region.bam.bai', checkIfExists: true)
                ])
                input[1] = Channel.of([
                    meta,
                    file('$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/hg002_chr20_90000_to_100000.dnascope.gvcf.gz', checkIfExists: true),
                    file('$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/hg002_chr20_90000_to_100000.dnascope.gvcf.gz.tbi', checkIfExists: true)
                ])
                input[2] = "$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/baf_positions.tsv"
                input[3] = "$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/panel_of_normals.hd5"
                """
            }
        }

        then {
            def cov = workflow.out.cov_bed_tbi
            def baf = workflow.out.baf_bed_tbi

            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }

    test("prepare_gens_inputs - stub") {
        when {
            workflow {
                """
                def meta = [ id: 'HG002', single_end: false ]
                input[0] = Channel.of([
                    meta,
                    file('$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/hg002_region.bam', checkIfExists: true),
                    file('$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/hg002_region.bam.bai', checkIfExists: true)
                ])
                input[1] = Channel.of([
                    meta,
                    file('$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/hg002_chr20_90000_to_100000.dnascope.gvcf.gz', checkIfExists: true),
                    file('$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/hg002_chr20_90000_to_100000.dnascope.gvcf.gz.tbi', checkIfExists: true)
                ])
                input[2] = "$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/baf_positions.tsv"
                input[3] = "$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/panel_of_normals.hd5"
                """
            }
        }

        then {
            def cov = workflow.out.cov_bed_tbi
            def baf = workflow.out.baf_bed_tbi

            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }
}
