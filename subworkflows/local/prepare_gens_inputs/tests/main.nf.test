// FIXME: Look through and test this
// FIXME: Run both with and without pon stubs

nextflow_workflow {

    name "Test Workflow PREPARE_GENS_INPUTS"
    script "../main.nf"
    workflow "PREPARE_GENS_INPUTS"

    options "-stub"

    // input[2] = "$projectDir/subworkflows/local/prepare_gens_inputs/tests/assets/baf_positions.tsv"

    test("prepare_gens_inputs") {
        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'HG002', single_end: false ],
                    file(params.pipelines_testdata_base_path + 'testdata/HG002_PacBio_Revio.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'testdata/HG002_PacBio_Revio.bam.bai', checkIfExists: true)
                ])
                input[1] = Channel.of([
                    [ id: 'HG002', single_end: false ],
                    file(params.pipelines_testdata_base_path + 'testdata/HG002_deepvariant.g.vcf.gz', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'testdata/HG002_deepvariant.g.vcf.gz.tbi', checkIfExists: true)
                ])
                input[2] = file("/trannel/dev/jakob/src/test-datasets/testdata/gnomad_0.05_subset.txt")
                input[3] = file("/trannel/dev/jakob/src/test-datasets/testdata/pon.hdf5")
                """
            }
        }

        then {
            def cov = workflow.out.cov_bed_tbi
            def baf = workflow.out.baf_bed_tbi

            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }

    test("prepare_gens_inputs - stub") {
        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'HG002', single_end: false ],
                    file(params.pipelines_testdata_base_path + 'testdata/HG002_PacBio_Revio.bam', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'testdata/HG002_PacBio_Revio.bam.bai', checkIfExists: true)
                ])
                input[1] = Channel.of([
                    [ id: 'HG002', single_end: false ],
                    file(params.pipelines_testdata_base_path + 'testdata/HG002_deepvariant.g.vcf.gz', checkIfExists: true),
                    file(params.pipelines_testdata_base_path + 'testdata/HG002_deepvariant.g.vcf.gz.tbi', checkIfExists: true)
                ])
                input[2] = file("/trannel/dev/jakob/src/test-datasets/testdata/gnomad_0.05_subset.txt")
                input[3] = file("/trannel/dev/jakob/src/test-datasets/testdata/pon.hdf5")
                """
            }
        }

        then {
            def cov = workflow.out.cov_bed_tbi
            def baf = workflow.out.baf_bed_tbi

            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }
}
