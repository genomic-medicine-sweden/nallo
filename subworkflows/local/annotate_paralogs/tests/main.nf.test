nextflow_workflow {

    name "Test Subworkflow ANNOTATE_PARALOGS"
    script "../main.nf"
    workflow "ANNOTATE_PARALOGS"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "subworkflows/annotate_paralogs"
    tag "paraphase"
    tag "paraphrase"

    setup {
        run("GUNZIP") {
            script "../../../../modules/nf-core/gunzip/main.nf"
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.pipelines_testdata_base_path + 'reference/hg38.test.fa.gz', checkIfExists: true)
                ]
                """
            }

        }
        run("SAMTOOLS_FAIDX") {
            script "../../../../modules/nf-core/samtools/faidx/main.nf"
            process {
                """
                input[0] = GUNZIP.out.gunzip
                input[1] = [[],[]]
                input[2] = false
                """
            }
        }
        run("PARAPHASE") {
            script "../../../../modules/nf-core/paraphase/main.nf"
            process {
                """
                input[0] = channel.of(
                    [
                        [ id: 'HG002', family_id: 'NIST' ],
                        file(params.pipelines_testdata_base_path + 'testdata/HG002_PacBio_Revio.bam', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'testdata/HG002_PacBio_Revio.bam.bai', checkIfExists: true)
                    ],
                    [
                        [ id: 'HG003', family_id: 'NIST' ],
                        file(params.pipelines_testdata_base_path + 'testdata/HG003_PacBio_Revio.bam', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'testdata/HG003_PacBio_Revio.bam.bai', checkIfExists: true)
                    ],
                    [
                        [ id: 'HG004', family_id: 'NIST2' ],
                        file(params.pipelines_testdata_base_path + 'testdata/HG004_PacBio_Revio.bam', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'testdata/HG004_PacBio_Revio.bam.bai', checkIfExists: true)
                    ]

                )
                input[1] = GUNZIP.out.gunzip
                input[2] = [[],[]]
                """
            }
        }
    }

    test("two familes, multiple sampels - json format - no rules") {

        when {
            workflow {
                """
                input[0] = PARAPHASE.out.json
                input[1] = 'json'
                input[2] = [[],[]]
                """
            }
        }
        then {
            assert workflow.success
            assertAll(
                { assert snapshot(workflow.out).match() }
            )
        }
    }

    test("two familes, multiple sampels - tsv format - rules") {

        when {
            workflow {
                """
                input[0] = PARAPHASE.out.json
                input[1] = 'tsv'
                input[2] = [
                    [ id:'rules' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/yaml/rules.yaml', checkIfExists: true)
                ]
                """
            }
        }
        then {
            assert workflow.success
            assertAll(
                { assert snapshot(workflow.out).match() }
            )
        }
    }

    test("two familes, multiple sampels - tsv format - rules - stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = PARAPHASE.out.json
                input[1] = 'tsv'
                input[2] = [
                    [ id:'rules' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/yaml/rules.yaml', checkIfExists: true)
                ]
                """
            }
        }
        then {
            assert workflow.success
            assertAll(
                { assert snapshot(workflow.out).match() }
            )
        }
    }
}
