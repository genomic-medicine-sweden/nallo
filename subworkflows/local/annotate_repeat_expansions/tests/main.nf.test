nextflow_workflow {

    name "Test Subworkflow ANNOTATE_REPEAT_EXPANSIONS"
    script "../main.nf"
    workflow "ANNOTATE_REPEAT_EXPANSIONS"
    config "./nextflow.config"

    setup {
        run("GUNZIP") {
            script "../../../../modules/nf-core/gunzip/main.nf"
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.pipelines_testdata_base_path + 'reference/hg38.test.fa.gz', checkIfExists: true)
                ]
                """
            }

        }

        run("SAMTOOLS_FAIDX") {
            script "../../../../modules/nf-core/samtools/faidx/main.nf"
            process {
                """
                input[0] = GUNZIP.out.gunzip
                input[1] = [[],[]]
                input[2] = false
                """
            }

        }

        run("CALL_REPEAT_EXPANSIONS_TRGT") {
            script "../../../../subworkflows/local/call_repeat_expansions_trgt/main.nf"
            process {
                """
                input[0] = Channel.of(
                    [
                        [ id:'HG002', family_id: 'family', sex: 1 ],
                        file(params.pipelines_testdata_base_path + 'testdata/HG002_PacBio_Revio.bam', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'testdata/HG002_PacBio_Revio.bam.bai', checkIfExists: true)
                    ],
                    [
                        [ id:'HG003', family_id: 'family', sex: 1 ],
                        file(params.pipelines_testdata_base_path + 'testdata/HG003_PacBio_Revio.bam', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'testdata/HG003_PacBio_Revio.bam.bai', checkIfExists: true)
                    ],
                    [
                        [ id:'HG004', family_id: 'family', sex: 2 ],
                        file(params.pipelines_testdata_base_path + 'testdata/HG004_PacBio_Revio.bam', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'testdata/HG004_PacBio_Revio.bam.bai', checkIfExists: true)
                    ]
                )
                input[1] = GUNZIP.out.gunzip.collect()
                input[2] = SAMTOOLS_FAIDX.out.fai.collect()
                input[3] = Channel.of([
                    [ id: 'pathogenic_repeats' ],
                    file(params.pipelines_testdata_base_path + 'reference/pathogenic_repeats.hg38.bed')
                ]).collect()
                input[4] = false
                """
            }
        }
    }

    test("stranger") {

        when {
            workflow {
                """
                input[0] = CALL_REPEAT_EXPANSIONS_TRGT.out.family_vcf
                input[1] = [[],[]]
                input[2] = CALL_REPEAT_EXPANSIONS_TRGT.out.sample_vcf
                    .map { meta, vcf ->
                        [[ id: 'traning_set' ], vcf]
                    }
                    .groupTuple()
                input[3] = Channel.of([
                    [ id: 'stranger_variant_catalog' ],
                    file(params.pipelines_testdata_base_path + 'reference/variant_catalog_grch38.json')
                ])
                input[4] = false
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                // stranger INFO tags are unstable: https://github.com/Clinical-Genomics/stranger/issues/109
                // strdrop header line is malformed: https://github.com/dnil/strdrop/issues/29
                { assert snapshot(
                    file(workflow.out.vcf.get(0).get(1)).name,
                    file(workflow.out.tbi.get(0).get(1)).name,
                ).match() }
            )
        }

    }

    test("stranger and strdrop") {

        when {
            workflow {
                """
                input[0] = CALL_REPEAT_EXPANSIONS_TRGT.out.family_vcf
                input[1] = [[],[]]
                input[2] = CALL_REPEAT_EXPANSIONS_TRGT.out.sample_vcf
                    .map { meta, vcf ->
                        [[ id: 'traning_set' ], vcf]
                    }
                    .groupTuple()
                input[3] = Channel.of([
                    [ id: 'stranger_variant_catalog' ],
                    file(params.pipelines_testdata_base_path + 'reference/variant_catalog_grch38.json')
                ])
                input[4] = true
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                // stranger INFO tags are unstable: https://github.com/Clinical-Genomics/stranger/issues/109
                // strdrop header line is malformed: https://github.com/dnil/strdrop/issues/29
                { assert snapshot(
                    file(workflow.out.vcf.get(0).get(1)).name,
                    file(workflow.out.tbi.get(0).get(1)).name,
                ).match() }
            )
        }

    }

    test("stranger and strdrop with json") {

        when {
            workflow {
                """
                input[0] = CALL_REPEAT_EXPANSIONS_TRGT.out.family_vcf
                input[1] = Channel.of([
                    [ id: 'strdrop_training_set_json' ],
                    file(params.pipelines_testdata_base_path + 'reference/strdrop_training_set.json')
                ])
                input[2] = [[],[]]
                input[3] = Channel.of([
                    [ id: 'stranger_variant_catalog' ],
                    file(params.pipelines_testdata_base_path + 'reference/variant_catalog_grch38.json')
                ])
                input[4] = true
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                // stranger INFO tags are unstable: https://github.com/Clinical-Genomics/stranger/issues/109
                // strdrop header line is malformed: https://github.com/dnil/strdrop/issues/29
                { assert snapshot(
                    file(workflow.out.vcf.get(0).get(1)).name,
                    file(workflow.out.tbi.get(0).get(1)).name,
                ).match() }
            )
        }

    }

    test("stranger -stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = CALL_REPEAT_EXPANSIONS_TRGT.out.family_vcf
                input[1] = [[],[]]
                input[2] = CALL_REPEAT_EXPANSIONS_TRGT.out.sample_vcf
                    .map { meta, vcf ->
                        [[ id: 'traning_set' ], vcf]
                    }
                    .groupTuple()
                input[3] = Channel.of([
                    [ id: 'stranger_variant_catalog' ],
                    file(params.pipelines_testdata_base_path + 'reference/variant_catalog_grch38.json')
                ])
                input[4] = false
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }

    }

    test("stranger and strdrop -stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = CALL_REPEAT_EXPANSIONS_TRGT.out.family_vcf
                input[1] = [[],[]]
                input[2] = CALL_REPEAT_EXPANSIONS_TRGT.out.sample_vcf
                    .map { meta, vcf ->
                        [[ id: 'traning_set' ], vcf]
                    }
                    .groupTuple()
                input[3] = Channel.of([
                    [ id: 'stranger_variant_catalog' ],
                    file(params.pipelines_testdata_base_path + 'reference/variant_catalog_grch38.json')
                ])
                input[4] = true
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }

    }

    test("stranger and strdrop with json -stub") {

        options "-stub"

        when {
            workflow {
                """
                input[0] = CALL_REPEAT_EXPANSIONS_TRGT.out.family_vcf
                input[1] = [[],[]]
                input[2] = Channel.of([
                    [ id: 'strdrop_training_set_json' ],
                    file(params.pipelines_testdata_base_path + 'reference/strdrop_training_set.json')
                ])
                input[3] = Channel.of([
                    [ id: 'stranger_variant_catalog' ],
                    file(params.pipelines_testdata_base_path + 'reference/variant_catalog_grch38.json')
                ])
                input[4] = true
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }

    }
}
